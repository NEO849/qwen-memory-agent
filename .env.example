# Kopiere zu .env und trage deinen echten Key ein. .env ist gitignored.

# API-Key aus Alibaba Model Studio (DashScope)
DASHSCOPE_API_KEY=

# Endpoint: international vs. China. Für ein Konto mit Region Germany i.d.R. der intl-Endpoint.
# intl:  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# china: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Modell — final im Plan-Mode festlegen (qwen-plus solide Default, qwen-max stärker/teurer)
QWEN_MODEL=qwen-plus
